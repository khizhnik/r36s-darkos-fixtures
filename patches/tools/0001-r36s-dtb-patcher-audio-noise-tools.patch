+
+  awk '
+    function node_name(line,   s) {
+      s = line
+      sub(/^[[:space:]]*/, "", s)
+      sub(/\{[[:space:]]*$/, "", s)
+      sub(/^[^[:space:]:]+:[[:space:]]*/, "", s)
+      sub(/[[:space:]]*$/, "", s)
+      return s
+    }
+    function top() {
+      return sp > 0 ? stack[sp] : ""
+    }
+    function parent() {
+      return sp > 1 ? stack[sp - 1] : ""
+    }
+    function push(name) {
+      stack[++sp] = name
+    }
+    function pop() {
+      if (sp > 0) {
+        delete stack[sp]
+        sp--
+      }
+    }
+    {
+      line = $0
+
+      if (line ~ /\{$/) {
+        name = node_name(line)
+        push(name)
+        print line
+        next
+      }
+
+      current = top()
+      if (current == "codec" && parent() == "pmic@20") {
+        if (line ~ /^[[:space:]]*spk-ctl-gpios = /) {
+          next
+        }
+        if (line ~ /^[[:space:]]*spk-mute-delay-ms = /) {
+          next
+        }
+      } else if (current == "simple-audio-card,codec" && parent() == "rk817-sound") {
+        if (line ~ /^[[:space:]]*spk-con-gpio = /) {
+          next
+        }
+      }
+
+      if (line ~ /^[[:space:]]*\};[[:space:]]*$/) {
+        print line
+        pop()
+        next
+      }
+
+      print line
+    }
+  ' "$input_dts" > "$output_dts"
+}
