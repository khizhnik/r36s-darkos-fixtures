+  write_temp_replacement "$rebuilt_dtb"
+  sync
+  target_sha="$(sha256sum "$TARGET_DTB" | awk '{print $1}')"
+  [ "$target_sha" = "$rebuilt_sha" ] || die "Target DTB hash mismatch after replacement."
